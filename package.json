{
  "name": "desfrenewebsite",
  "version": "1.0.0",
  "description": "Source of the Desfrene Website. You can browse it live here : [desfrene.fr](https://desfrene.fr)",
  "main": "index.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:11ty": "eleventy --serve",
    "dev:css": "npx @tailwindcss/cli -i ./styles.css -o ./_site/styles.css --watch",
    "build": "npm-run-all build:*",
    "build:11ty": "eleventy",
    "build:css": "npx @tailwindcss/cli -i ./styles.css -o ./_site/styles.css --minify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/desfreng/DesfreneWebsite.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/desfreng/DesfreneWebsite/issues"
  },
  "homepage": "https://github.com/desfreng/DesfreneWebsite#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@tailwindcss/cli": "^4.2.2",
    "html-minifier-next": "^5.2.1",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.2"
  }
}
